% Manglekit Kubernetes Safety Policy
% Enforced by the supervisor pre-check (Assess) during action execution.
% Struct fields tagged with `mangle:"..."` are reflected as Datalog facts
% with the tag value as predicate name and "ActionRequest" as subject.

Decl req_operation(Req, Op).
Decl is_peak_hour(Req, Val).
Decl pod_namespace(Req, Ns).
Decl pod_tier(Req, Tier).

% Rule 1: Deny deletion of a critical pod
deny(Req) :-
    req_operation(Req, "DELETE"),
    pod_tier(Req, "critical").

% Rule 2: Deny any write operation on the production namespace during peak hours
deny(Req) :-
    pod_namespace(Req, "production"),
    req_operation(Req, Op),
    Op != "READ",
    is_peak_hour(Req, "true").
